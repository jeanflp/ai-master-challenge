# Supabase — copie para .env.local e preencha com seu projeto
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (reclassificação, rascunhos, chat RAG)
OPENAI_API_KEY=sk-your-openai-api-key

# Classificador sklearn — produção (Render). Se vazio, usa Python local (dev).
CLASSIFIER_API_URL=https://your-service.onrender.com

# Python local (só dev, quando CLASSIFIER_API_URL não está definida)
PYTHON_PATH=python
